{
  "mcpServers": {
    "milknado": {
      "command": "npx",
      "args": ["tsx", "src/index.ts", "mcp"]
    },
    "tilth": {
      "command": "npx",
      "args": ["tilth", "--mcp", "--edit"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    }
  }
}
